// ─────────────────────────────────────────────────────────────
//  Prisma Schema — Faviola Velarde CRM
//  Sprint 1: Tenancy · Auth · RBAC (Blueprint §3).
//  Multi-tenant por columna `tenantId` (aislamiento en capa de app).
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantPlan {
  STARTER
  PRO
  TEAM
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

/// Organización / cuenta. Raíz del aislamiento multi-tenant.
model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  plan      TenantPlan   @default(STARTER)
  status    TenantStatus @default(ACTIVE)
  settings  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  users      User[]
  roles      Role[]
  clients    Client[]
  properties Property[]
  deals      Deal[]
  visits     Visit[]
  academyPrograms AcademyProgram[]
  academyLeads    AcademyLead[]
  academyStudents AcademyStudent[]
  academyEnrollments AcademyEnrollment[]
  channelAccounts ChannelAccount[]
  conversations   Conversation[]

  @@map("tenants")
}

/// Usuario del sistema (asesor, asistente, admin de la cuenta).
model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions        Session[]
  ownedClients    Client[]
  agentProperties Property[]
  deals           Deal[]
  visits          Visit[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

/// Rol dentro de un tenant (ADMIN, ASESOR, ASISTENTE, ...).
model Role {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

/// Catálogo global de permisos (recurso.acción). No lleva tenantId.
model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

/// Relación N:M Role ↔ Permission.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Sesión de refresh token (rotación + detección de reuso).
model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
//  Sprint 2 — Clientes (compradores / vendedores) + timeline
// ─────────────────────────────────────────────────────────────

enum ClientType {
  BUYER
  SELLER
  BOTH
}

enum ClientTemperature {
  HOT
  WARM
  COLD
}

enum Operation {
  SALE
  RENT
}

enum ActivityType {
  NOTE
  CALL
  MESSAGE
  VISIT
  EMAIL
  STATUS_CHANGE
  CREATED
}

enum ActorType {
  USER
  AI
  SYSTEM
}

/// Cliente: comprador, vendedor o ambos.
model Client {
  id            String            @id @default(uuid())
  tenantId      String
  type          ClientType        @default(BUYER)
  firstName     String
  lastName      String
  phone         String?
  email         String?
  source        String?
  temperature   ClientTemperature @default(WARM)
  score         Int               @default(0)
  notes         String?
  ownerId       String
  lastContactAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  requirement   ClientRequirement?
  activities    ActivityLog[]
  properties    Property[]
  matches       Match[]
  deals         Deal[]
  visits        Visit[]
  conversations Conversation[]

  @@index([tenantId, type])
  @@index([tenantId, temperature])
  @@index([tenantId, ownerId])
  @@index([tenantId, lastContactAt])
  @@map("clients")
}

/// Requisitos de búsqueda del comprador (1:1 con Client).
model ClientRequirement {
  id           String    @id @default(uuid())
  clientId     String    @unique
  operation    Operation @default(SALE)
  propertyType String?
  budgetMin    Int?
  budgetMax    Int?
  currency     String    @default("PEN")
  bedroomsMin  Int?
  bathroomsMin Int?
  areaMin      Int?
  zones        String[]
  notes        String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_requirements")
}

/// Registro de actividad (timeline). Fuente única del historial del cliente.
model ActivityLog {
  id        String       @id @default(uuid())
  tenantId  String
  clientId  String
  type      ActivityType
  message   String
  meta      Json         @default("{}")
  actorType ActorType    @default(USER)
  actorId   String?
  createdAt DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId, clientId, createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────
//  Sprint 3 — Propiedades (inventario) + media
// ─────────────────────────────────────────────────────────────

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  OFF
}

enum MediaType {
  IMAGE
  DOC
  VIDEO
}

/// Propiedad del inventario (venta / alquiler).
model Property {
  id            String         @id @default(uuid())
  tenantId      String
  code          String
  title         String
  description   String?
  operation     Operation      @default(SALE)
  propertyType  String?
  status        PropertyStatus @default(AVAILABLE)
  price         Int
  currency      String         @default("PEN")
  bedrooms      Int?
  bathrooms     Int?
  area          Int?
  builtArea     Int?
  address       String?
  district      String?
  city          String?
  lat           Float?
  lng           Float?
  features      Json           @default("{}")
  ownerClientId String?
  agentId       String
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent         User            @relation(fields: [agentId], references: [id], onDelete: Restrict)
  owner         Client?         @relation(fields: [ownerClientId], references: [id], onDelete: SetNull)
  media         PropertyMedia[]
  matches       Match[]
  deals         Deal[]
  visits        Visit[]
  conversations Conversation[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, operation, price])
  @@index([tenantId, district])
  @@map("properties")
}

/// Imagen / documento asociado a una propiedad.
model PropertyMedia {
  id         String    @id @default(uuid())
  propertyId String
  type       MediaType @default(IMAGE)
  url        String
  order      Int       @default(0)
  isCover    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_media")
}

// ─────────────────────────────────────────────────────────────
//  Sprint 4 — Coincidencias (matching comprador ↔ propiedad)
// ─────────────────────────────────────────────────────────────

enum MatchStatus {
  NEW
  SENT
  VIEWED
  DISCARDED
  CONVERTED
}

/// Coincidencia calculada entre un comprador y una propiedad.
model Match {
  id         String      @id @default(uuid())
  tenantId   String
  clientId   String
  propertyId String
  score      Int
  reasons    Json        @default("[]")
  status     MatchStatus @default(NEW)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clientId, propertyId])
  @@index([tenantId, score])
  @@index([tenantId, status])
  @@map("matches")
}

// ─────────────────────────────────────────────────────────────
//  Sprint 5 — Pipeline (negociaciones)
// ─────────────────────────────────────────────────────────────

enum DealStage {
  NEW
  CONTACTED
  VISIT
  OFFER
  NEGOTIATION
  CLOSING
  WON
  LOST
}

/// Negociación / oportunidad de venta o alquiler.
model Deal {
  id                String    @id @default(uuid())
  tenantId          String
  clientId          String
  propertyId        String?
  sellerClientId    String?
  agentId           String
  stage             DealStage @default(NEW)
  value             Int?
  currency          String    @default("PEN")
  commissionPct     Float?
  commissionAmount  Int?
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent    User      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([tenantId, stage])
  @@index([tenantId, agentId])
  @@map("deals")
}

// ─────────────────────────────────────────────────────────────
//  Sprint 5 (parte 2) — Visitas
// ─────────────────────────────────────────────────────────────

enum VisitStatus {
  SCHEDULED
  DONE
  CANCELLED
  NOSHOW
}

/// Visita agendada a una propiedad con un cliente.
model Visit {
  id          String      @id @default(uuid())
  tenantId    String
  clientId    String
  propertyId  String?
  agentId     String
  scheduledAt DateTime
  durationMin Int         @default(60)
  status      VisitStatus @default(SCHEDULED)
  feedback    String?
  outcome     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent    User      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@map("visits")
}

enum AcademyFormat {
  WORKSHOP
  TALK
  TRAINING
}

enum AcademyProgramStatus {
  DRAFT
  OPEN
  CLOSED
}

enum AcademyLeadStatus {
  NEW
  CONTACTED
  ENROLLED
  DISCARDED
}

enum AcademyStudentStatus {
  ACTIVE
  PAUSED
}

model AcademyProgram {
  id          String               @id @default(uuid())
  tenantId    String
  title       String
  format      AcademyFormat
  description String?
  modality    String               @default("En vivo")
  audience    String?
  startsAt    DateTime?
  duration    String?
  capacity    Int?
  status      AcademyProgramStatus @default(OPEN)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads       AcademyLead[]
  enrollments AcademyEnrollment[]

  @@index([tenantId, status])
  @@index([tenantId, format])
  @@map("academy_programs")
}

model AcademyLead {
  id              String            @id @default(uuid())
  tenantId        String
  programId       String?
  firstName       String
  lastName        String?
  phone           String
  email           String?
  formatInterest  AcademyFormat?
  experienceLevel String?
  objective       String?
  source          String            @default("Landing Academia FV")
  status          AcademyLeadStatus @default(NEW)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program AcademyProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("academy_leads")
}

model AcademyStudent {
  id         String               @id @default(uuid())
  tenantId   String
  firstName  String
  lastName   String?
  phone      String?
  email      String
  accessCode String
  status     AcademyStudentStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments AcademyEnrollment[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("academy_students")
}

model AcademyEnrollment {
  id        String   @id @default(uuid())
  tenantId  String
  studentId String
  programId String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program AcademyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([studentId, programId])
  @@index([tenantId, programId])
  @@map("academy_enrollments")
}

// ─────────────────────────────────────────────────────────────
//  Bandeja omnicanal — conversaciones de redes + asistente IA
// ─────────────────────────────────────────────────────────────

enum InboxChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  TIKTOK
  INTERNAL
}

enum ChannelStatus {
  CONNECTED
  PENDING
  DISCONNECTED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageAuthor {
  CONTACT
  AGENT
  AI
}

/// Cuenta de un canal conectada a la bandeja (WhatsApp, IG, FB, TikTok).
model ChannelAccount {
  id          String        @id @default(uuid())
  tenantId    String
  channel     InboxChannel
  displayName String
  handle      String?
  status      ChannelStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel])
  @@map("channel_accounts")
}

/// Conversación unificada (un hilo con un contacto por un canal).
model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  channel       InboxChannel       @default(WHATSAPP)
  contactName   String
  contactHandle String?
  clientId      String?
  propertyId    String?
  status        ConversationStatus @default(OPEN)
  tags          String[]
  notes         String?
  lastPreview   String?
  lastMessageAt DateTime           @default(now())
  unread        Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  messages InboxMessage[]

  @@index([tenantId, status])
  @@index([tenantId, channel])
  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

/// Mensaje individual dentro de una conversación.
model InboxMessage {
  id             String           @id @default(uuid())
  tenantId       String
  conversationId String
  direction      MessageDirection
  author         MessageAuthor    @default(CONTACT)
  body           String
  createdAt      DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("inbox_messages")
}
