# ──────────────────────────────────────────────────────────────
#  Faviola Velarde CRM — Variables de entorno
#  Copia este archivo a `.env` (NO se versiona) antes de arrancar.
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# PostgreSQL
POSTGRES_USER=faviola
POSTGRES_PASSWORD=faviola
POSTGRES_DB=faviola_crm
POSTGRES_PORT=5432
# Host (dev local). En Docker el host es `postgres` (ver docker-compose.yml).
DATABASE_URL=postgresql://faviola:faviola@localhost:5432/faviola_crm?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO (almacenamiento S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000

# MailHog (SMTP de desarrollo)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025

# Auth (placeholders — se consumen a partir del Sprint 1)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
