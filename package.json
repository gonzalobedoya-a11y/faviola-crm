{
  "name": "faviola-crm",
  "version": "0.0.0",
  "private": true,
  "description": "Faviola Velarde — CRM Inmobiliario Inteligente (monorepo)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml}\"",
    "prisma:generate": "pnpm --filter @faviola/api prisma:generate",
    "env:up": "docker compose up -d",
    "env:down": "docker compose down",
    "env:logs": "docker compose logs -f",
    "env:reset": "docker compose down -v",
    "up": "docker compose up --build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
